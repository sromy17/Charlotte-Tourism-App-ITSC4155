# Environment variables for CLTourism backend
DATABASE_URL=sqlite:///./cltourism.db
DATABASE_URL_ASYNC=sqlite+aiosqlite:///./cltourism.db
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
OPENWEATHER_API_KEY=your-openweather-api-key
YELP_API_KEY=your-yelp-api-key
TICKETMASTER_API_KEY=your-ticketmaster-api-key
TOMTOM_API_KEY=your-tomtom-api-key
FRONTEND_URL=http://localhost:3000

DATABASE_URL=postgresql://niner_user:niner_password@localhost:5432/cltourism_db
DATABASE_URL_ASYNC=postgresql+asyncpg://niner_user:niner_password@localhost:5432/cltourism_db
